# Canonical site URL (metadata, sitemap, JSON-LD). If unset:
#   • npm run dev → http://localhost:3010 (see package.json; avoids clashing with :3000)
#   • next build / production → https://seattlewallco.com
# NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Contact form — required for production email (verify sending domain in Resend)
# RESEND_API_KEY=
# CONTACT_INBOX_EMAIL=you@example.com
# RESEND_FROM_EMAIL=hello@seattlewallco.com

# /create wall art tool (OpenAI DALL·E 3 — billed per image on your OpenAI account)
# OPENAI_API_KEY=
# Max AI preview generations per browser per ~24h (cookie-based; not a hard fraud barrier)
# WALL_ART_DAILY_LIMIT=6
